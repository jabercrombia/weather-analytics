    {
      "type": "timeseries",
      "title": "Rain",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "id": 4,
      "datasource": {
        "type": "elasticsearch",
        "uid": "P31C819B24CF3C3C7"
      },
      "targets": [
        {
          "refId": "A",
          "query": "*",
          "metrics": [{"type": "avg", "id": "1", "field": "rain"}],
          "bucketAggs": [{"type": "date_histogram", "id": "2", "field": "timestamp", "settings": {"interval": "auto"}}]
        }
      ],
      "fieldConfig": {
