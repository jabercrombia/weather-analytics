{
  "id": null,
  "title": "Weather Dashboard",
  "uid": "weather-dashboard",
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Temperature",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "id": 1,
      "datasource": {
        "type": "elasticsearch",
        "uid": "P31C819B24CF3C3C7"
      },
      "targets": [
        {
          "refId": "A",
          "query": "*",
          "metrics": [{"type": "avg", "id": "1", "field": "temperature"}],
          "bucketAggs": [{"type": "date_histogram", "id": "2", "field": "timestamp", "settings": {"interval": "auto"}}]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "fahrenheit",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Humidity",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "id": 2,
      "datasource": {
        "type": "elasticsearch",
        "uid": "P31C819B24CF3C3C7"
      },
      "targets": [
        {
          "refId": "A",
          "query": "*",
          "metrics": [{"type": "avg", "id": "1", "field": "humidity"}],
          "bucketAggs": [{"type": "date_histogram", "id": "2", "field": "timestamp", "settings": {"interval": "auto"}}]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Wind Speed",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "id": 3,
      "datasource": {
        "type": "elasticsearch",
        "uid": "P31C819B24CF3C3C7"
      },
      "targets": [
        {
          "refId": "A",
          "query": "*",
          "metrics": [{"type": "avg", "id": "1", "field": "wind_speed"}],
          "bucketAggs": [{"type": "date_histogram", "id": "2", "field": "timestamp", "settings": {"interval": "auto"}}]
        }
